# === 필수 설정 ===

# Google Gemini API 키 (AI HTML 수정/PDF 변환용)
GEMINI_API_KEY=your-gemini-api-key-here

# === 선택 설정 (Docker 사용 시 docker-compose.yml에서 설정됨) ===

# 개발 모드 (true: IP 필터 비활성화, false: 프로덕션)
# DEV_MODE=true

# 데이터베이스 경로
# DATABASE_URL=sqlite:///data/db/bid_proposal.db

# 파일 저장 경로
# UPLOAD_DIR=data/uploads
# THUMBNAIL_DIR=data/thumbnails
# GENERATED_DIR=data/generated

# IP 화이트리스트 설정 파일
# ALLOWED_IPS_FILE=config/allowed_ips.yaml

# 프론트엔드 API URL (Vite 개발 서버용)
VITE_API_BASE_URL=http://localhost:8000/api
